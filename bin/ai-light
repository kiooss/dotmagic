#!/bin/sh
# ai-light — drive the LAN AI status light.
#
# A general ambient status indicator: any tool can push a state, and this
# script arbitrates between concurrent sources before touching the device.
# It knows nothing about Claude Code (see ~/.claude/hooks/ai-light.sh for that).
#
# Each source holds a claim (a one-line file) that expires after --ttl seconds.
# Expiry is evaluated lazily, on the next invocation — there is no timer and no
# daemon. So a stale claim stops *masking other sources* as soon as anything
# calls this script again, but it cannot turn the light off by itself: if the
# only claimant dies and nothing else ever calls in, the device keeps showing
# that last state. Callers that care must `clear` on the way out.
#
# Never fails its caller: it runs inside Claude Code hooks and build pipelines,
# where a non-zero exit would be actively harmful. Usage errors are the one
# exception (exit 2) — those are bugs in the caller, not runtime conditions.

set -u

host="${AI_LIGHT_HOST:-192.168.2.24}"
dir="${AI_LIGHT_DIR:-${TMPDIR:-/tmp}/ai-light}"
last="$dir/.last"
lockdir="$dir/.lock"

usage() {
  cat >&2 <<'EOF'
usage: ai-light set <state> [--source NAME] [--ttl SECONDS] [--priority normal|alert]
       ai-light clear [--source NAME]
       ai-light status

  <state>      ready thinking working waiting error off   (off retires the source)
  --source     who is speaking. default: default
  --ttl        seconds the claim stays valid. default: 60
  --priority   alert beats normal. default: normal
EOF
  exit 2
}

# Sources are used as filenames and arrive from callers (a Claude session_id, a
# script's name); keep them to a safe charset rather than trusting them.
sanitize() {
  printf %s "$1" | tr -c 'A-Za-z0-9_-' '_'
}

valid_state() {
  case "$1" in
    ready | thinking | working | waiting | error | off) return 0 ;;
    *) return 1 ;;
  esac
}

# Run a function with the state dir locked. `mkdir` is atomic on POSIX, which is
# all we need — and unlike flock(1) it actually exists on macOS.
#
# Without this, two hooks firing at once interleave their compute/push/record
# steps: the loser's stale winner lands on the device *after* the winner's, and
# both racing to write `.last` can shred it into a value that is not a state at
# all (observed: "errorng").
#
# A wedged holder is stolen from after ~1s rather than blocking: this runs
# inside hooks, where hanging is worse than a duplicate request.
with_lock() {
  mkdir -p "$dir" 2>/dev/null || return 0

  i=0
  until mkdir "$lockdir" 2>/dev/null; do
    i=$((i + 1))
    if [ "$i" -gt 20 ]; then
      rm -rf "$lockdir" 2>/dev/null
      mkdir "$lockdir" 2>/dev/null || return 0
      break
    fi
    sleep 0.05
  done
  trap 'rm -rf "$lockdir" 2>/dev/null' EXIT HUP INT TERM

  "$1"

  rm -rf "$lockdir" 2>/dev/null
  trap - EXIT HUP INT TERM
}

# Rank helpers. Higher number wins. Printed rather than returned because sh
# exit codes are a terrible place to put data.
urgency() {
  case "$1" in
    error) echo 5 ;;
    waiting) echo 4 ;;
    working) echo 3 ;;
    thinking) echo 2 ;;
    ready) echo 1 ;;
    *) echo 0 ;;
  esac
}

tier() {
  case "$1" in
    alert) echo 2 ;;
    *) echo 1 ;;
  esac
}

# The winning state across all live claims: highest tier, then highest urgency.
# Expired claims are skipped, which is how a killed session releases the light.
#
# No recency tiebreak is needed: urgency is a pure function of the state, so two
# claims that tie on urgency hold the same state and yield the same winner.
compute_winner() {
  now=$(date +%s)
  best=off
  best_tier=0
  best_urgency=0

  for f in "$dir"/*; do
    [ -f "$f" ] || continue
    case "${f##*/}" in .*) continue ;; esac
    read -r st ttl prio mt <"$f" || continue
    [ $((now - mt)) -gt "$ttl" ] && continue

    t=$(tier "$prio")
    u=$(urgency "$st")
    if [ "$t" -gt "$best_tier" ] ||
      { [ "$t" -eq "$best_tier" ] && [ "$u" -gt "$best_urgency" ]; }; then
      best="$st"
      best_tier="$t"
      best_urgency="$u"
    fi
  done

  printf '%s\n' "$best"
}

# Send the current winner to the device — but only if it changed. Claude's
# PreToolUse hook fires on every single tool call; without this check the light
# would be hammered and the hook would pay a round-trip each time.
#
# Short timeout, output discarded, never returns non-zero: an unplugged light
# must not break a build or a hook. `.last` records what the device was last
# known to accept, and is written only when it really did accept — `--fail` is
# what makes that true, since curl exits 0 on a 4xx/5xx body otherwise, and a
# rejected update would then be remembered as applied and never retried.
#
# Callers must hold the lock: this reads and writes `.last`.
push() {
  new=$(compute_winner)
  old=$(cat "$last" 2>/dev/null) || old=
  [ "$new" = "$old" ] && return 0

  if curl -s --fail --max-time 1 "http://$host/state?value=$new" >/dev/null 2>&1; then
    tmp="$dir/.last.$$"
    printf '%s' "$new" >"$tmp" 2>/dev/null && mv -f "$tmp" "$last" 2>/dev/null
  fi
  return 0
}

cmd_set() {
  [ $# -ge 1 ] || usage
  state="$1"
  shift
  valid_state "$state" || usage

  source=default
  ttl=60
  priority=normal
  while [ $# -gt 0 ]; do
    case "$1" in
      --source)
        source="${2:-}"
        shift 2 || usage
        ;;
      --ttl)
        ttl="${2:-}"
        shift 2 || usage
        ;;
      --priority)
        priority="${2:-}"
        shift 2 || usage
        ;;
      *) usage ;;
    esac
  done
  case "$priority" in normal | alert) ;; *) usage ;; esac

  # A non-numeric ttl used to sail through and write a claim that every later
  # `[ ... -gt ... ]` choked on — and since the comparison errored rather than
  # returning true, the claim was treated as live *forever*. An `alert` one
  # could then mask every other source until the state dir was wiped by hand.
  case "$ttl" in
    '' | *[!0-9]*) usage ;;
  esac
  [ "$ttl" -gt 0 ] || usage

  source=$(sanitize "$source")
  with_lock apply_set
}

apply_set() {
  if [ "$state" = off ]; then
    rm -f "$dir/$source"
  else
    # Write-then-rename: a concurrent reader never sees a half-written claim.
    tmp="$dir/.tmp.$$"
    printf '%s %s %s %s\n' "$state" "$ttl" "$priority" "$(date +%s)" >"$tmp" &&
      mv -f "$tmp" "$dir/$source"
  fi

  push
}

cmd_clear() {
  source=default
  while [ $# -gt 0 ]; do
    case "$1" in
      --source)
        source="${2:-}"
        shift 2 || usage
        ;;
      *) usage ;;
    esac
  done
  source=$(sanitize "$source")
  with_lock apply_clear
}

apply_clear() {
  rm -f "$dir/$source"
  push
}

cmd_status() {
  now=$(date +%s)
  for f in "$dir"/*; do
    [ -f "$f" ] || continue
    read -r st ttl prio mt <"$f" || continue
    [ $((now - mt)) -gt "$ttl" ] && continue
    printf 'source %s %s %s %s\n' "${f##*/}" "$st" "$prio" "$ttl"
  done
  printf 'winner: %s\n' "$(compute_winner)"
}

[ $# -ge 1 ] || usage
subcommand="$1"
shift
case "$subcommand" in
  set) cmd_set "$@" ;;
  clear) cmd_clear "$@" ;;
  status) cmd_status "$@" ;;
  *) usage ;;
esac
exit 0
