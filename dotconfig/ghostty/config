# Ghostty configuration
# docs: https://ghostty.org/docs/config
# reload: cmd+shift+, (reload_config) / show this file: cmd+, opens it
# validate: ghostty +validate-config

# ── Theme ────────────────────────────────────────────────────────────────
# Matches the kitty tokyonight_storm setup. `theme` can differ light/dark:
#   theme = light:TokyoNight Day,dark:TokyoNight Storm
# theme = TokyoNight Storm
# cursor-color = 4fd6be
# background-opacity = 0.9
# background-blur = 20
config-file = ?auto/theme.ghostty

# ── Font ─────────────────────────────────────────────────────────────────
# Monaspace Neon + all the texture-healing / ligature stylistic sets that
# were enabled in kitty. Ghostty pulls bold/italic faces from the family
# automatically, so only the base family is named.
# font-family = Monaspace Neon Var
# font-size = 12
# font-family = "JetBrains Mono"
# font-family = "Monaspace Argon Var"
# font-family = "PlemolJP"
font-family = "UDEV Gothic NF"
# font-family = "Moralerspace Neon"
font-size = 14

# calt = contextual alternates (texture healing), liga = ligatures,
# ss01-ss09 = Monaspace stylistic sets.
font-feature = calt
font-feature = liga
# font-feature = ss01
# font-feature = ss02
# font-feature = ss03
# font-feature = ss04
# font-feature = ss05
# font-feature = ss06
# font-feature = ss07
# font-feature = ss08
# font-feature = ss09

# Ghostty ships Nerd Font symbols built-in, so no symbol_map is needed.
# Slightly thicken glyphs on the Retina display (kitty had no equivalent).

font-thicken = true

# Note: Ghostty has no direct analog to kitty's `modify_font baseline -2`;
# use `adjust-cell-height` / `adjust-font-baseline` if vertical tweaking is
# needed later.

# ── Window ───────────────────────────────────────────────────────────────
# window-width = 1920
# window-height = 1200
window-padding-x = 8
window-padding-y = 6
window-padding-balance = true
# Native tab bar in the titlebar — clearest way to see many Claude sessions.
macos-titlebar-style = tabs
# window-inherit-working-directory = true
# window-inherit-font-size = true
# Restore window/tab/split layout on relaunch (does not restore processes).
window-save-state = always

# ── Appearance ───────────────────────────────────────────────────────────
# Frosted-glass background; blur only takes effect while translucent.
background-opacity = 0.95
background-blur = 20
# Dim the non-focused split so the active one stands out.
unfocused-split-opacity = 0.7
# Wider gamut for richer TokyoNight colors.
window-colorspace = display-p3
# Force a minimum fg/bg contrast so dim text never melts into the background.
minimum-contrast = 1.1

# ── macOS ────────────────────────────────────────────────────────────────
macos-option-as-alt = true
# quit-after-last-window-closed = true
mouse-hide-while-typing = true
# Distraction-free fullscreen for pairing with Claude.
macos-non-native-fullscreen = true
# Quick-terminal drops down from the top; snappy animation.
quick-terminal-position = top
quick-terminal-animation-duration = 0.1
# Keep the drop-down Claude session alive when it loses focus; show on the
# screen the mouse is on.
quick-terminal-autohide = false
quick-terminal-screen = mouse

# ── Behavior ─────────────────────────────────────────────────────────────
# Mouse-select copies straight to the clipboard (grab Claude's commands fast).
copy-on-select = clipboard
scrollback-limit = 10000000
# Shell integration: title updates, prompt-jumping, smart cursor, sudo.
shell-integration = detect
shell-integration-features = cursor,sudo,title
# Audible bell off; keep it subtle.
# link-url = true is the default (cmd+click opens URLs)

# ── Cursor ───────────────────────────────────────────────────────────────
cursor-style = bar
cursor-style-blink = true

# ── Keybinds ─────────────────────────────────────────────────────────────
# Ghostty uses `super` for cmd. These mirror the kitty_mod=cmd bindings.
keybind = super+shift+comma=reload_config
keybind = super+equal=increase_font_size:1
keybind = super+minus=decrease_font_size:1
keybind = super+zero=reset_font_size

# Tabs (kitty had cmd+]/cmd+[ and cmd+1..9)
keybind = super+right_bracket=next_tab
keybind = super+left_bracket=previous_tab

# shift+enter -> CSI u (kitty: map shift+enter send_text all \x1b[13;2u)
keybind = shift+enter=text:\x1b[13;2u

# Splits (native, independent of tmux)
keybind = super+d=new_split:right
keybind = super+shift+d=new_split:down
keybind = super+alt+left=goto_split:left
keybind = super+alt+right=goto_split:right
keybind = super+alt+up=goto_split:up
keybind = super+alt+down=goto_split:down
keybind = super+shift+enter=toggle_split_zoom

# Quake-style drop-down terminal, summonable from any app.
keybind = global:cmd+grave_accent=toggle_quick_terminal

# Chord prefix (tmux-like): press super+s, then the next key.
keybind = super+s>r=reload_config
keybind = super+s>1=goto_tab:1
keybind = super+s>2=goto_tab:2

# Clear the screen/scrollback.
keybind = super+k=clear_screen

# Jump between shell prompts (needs shell-integration) — fast nav across a
# long Claude session's command boundaries.
keybind = super+up=jump_to_prompt:-1
keybind = super+down=jump_to_prompt:1
