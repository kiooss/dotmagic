#!/usr/bin/env bash
# Pick a URL from a tmux pane's visible content with fzf and open it.
# Usage: tmux-url-fzf <pane_id>
set -uo pipefail

# Resolve the source pane. display-popup does NOT format-expand its command
# argument, so a binding can't pass #{pane_id}; from inside the popup the
# active pane still resolves to the launching pane, so query it directly.
pane="${1:-$(tmux display-message -p '#{pane_id}')}"

# Resolve the browser opener once.
case "$(uname)" in
  Darwin) opener="open" ;;
  *)      opener="xdg-open" ;;
esac

# Capture the visible pane (-J joins wrapped lines so split URLs survive),
# pull out URLs, promote bare www. hosts, strip trailing punctuation,
# reverse to most-recent-first, and dedup preserving order.
urls="$(
  tmux capture-pane -p -J -t "$pane" \
    | grep -oE "(https?://|www\.)[A-Za-z0-9._~:/?#@!\$&'()*+,;=%-]*[A-Za-z0-9/]" \
    | sed -E 's#\\.*##' \
    | sed -E 's#^www\.#https://www.#' \
    | sed -E 's#[],.;:!?"'"'"'>)}]+$##' \
    | awk 'NF' \
    | tail -r \
    | awk '!seen[$0]++'
)"

if [ -z "$urls" ]; then
  # The popup itself is bordered (-b rounded); just print the notice.
  d=$'\033[2m'; r=$'\033[0m'
  printf 'no URLs on this pane\n%spress any key%s\n' "$d" "$r"
  # -E closes the popup on exit; pause so the message is readable.
  read -rn1 -s
  exit 0
fi

selected="$(printf '%s\n' "$urls" \
  | fzf --multi \
        --prompt='url> ' \
        --pointer='▶' \
        --header='enter:open  tab:multi  esc:cancel' \
        --info=inline \
        --color='prompt:magenta,pointer:magenta,header:8' \
        --preview='echo {}' \
        --preview-window='down,1,border-top,wrap')" || exit 0

[ -z "$selected" ] && exit 0

while IFS= read -r url; do
  [ -n "$url" ] && "$opener" "$url"
done <<< "$selected"
