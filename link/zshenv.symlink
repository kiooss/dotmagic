# Bootstrap only — real env config lives in $ZDOTDIR/.zshenv.
# zsh picks which .zshenv to read before this file runs, so child shells
# (inherited ZDOTDIR) read $ZDOTDIR/.zshenv directly and skip this file;
# the first shell lands here and must chain explicitly.
export ZDOTDIR=$HOME/.config/zsh
[[ -f $ZDOTDIR/.zshenv ]] && source $ZDOTDIR/.zshenv
